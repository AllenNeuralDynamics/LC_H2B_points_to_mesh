#!/usr/bin/env bash
set -e

# install updated version of code-server
VERSION=4.100.3
mkdir /.code-server
cd /.code-server
curl -fL "https://github.com/coder/code-server/releases/download/v$VERSION/code-server-$VERSION-linux-amd64.tar.gz" \
  | tar -xz
ln -s /.code-server/code-server-$VERSION-linux-amd64/bin/code-server  /usr/bin/code-server
cd -

# default behavior: extensions are installed here and reinstalled when capsule is rebuilt,
# alternative: install extensions manually inside capsule filesystem, saved across rebuilds
install_extensions=true

if $install_extensions; then
  mkdir -p /.vscode/extensions
  code-server --extensions-dir=/.vscode/extensions --install-extension ms-toolsai.jupyter 
  code-server --extensions-dir=/.vscode/extensions --install-extension ms-python.python 
  code-server --extensions-dir=/.vscode/extensions --install-extension detachhead.basedpyright
else
  # move VS code extensions directory into capsule and symlink
  # (this may cause issues on the first run that will be solved by reloading VS code
  echo "mkdir -p /root/capsule/.vscode/extensions" >> /root/.profile
  ln -s /root/capsule/.vscode /.vscode
fi

# download and install vscode extension from file
# for extensions not available in the default open-vsx registry
download_and_install_extension() {
    publisher=$1
    name=$2
    version=$3
    file=/tmp/$publisher.$name.$version.vsix
    curl -fL http://${publisher}.gallery.vsassets.io/_apis/public/gallery/publisher/${publisher}/extension/${name}/${version}/assetbyname/Microsoft.VisualStudio.Services.VSIXPackage \
        --output $file
    code-server --extensions-dir=/.vscode/extensions --install-extension $file
}

# comment out as needed:
# for code-server 4.100
download_and_install_extension github copilot 1.326.0
download_and_install_extension github copilot-chat 0.27.3

# python/jupyter/etc can be installed using the standard code-server command directly
code-server --extensions-dir=/.vscode/extensions --install-extension ms-toolsai.jupyter
code-server --extensions-dir=/.vscode/extensions --install-extension ms-python.python

curl -LsSf https://astral.sh/uv/install.sh | \
    UV_INSTALL_DIR=/usr/local/bin sh
# --- Pinned dependencies: maximum-fidelity reconstruction of the original
# mesh-generation environment (2026-02-02, capsule c995ccc6, computation
# 8c0459de "Run 61097"). The mesh libraries were installed ad hoc in that
# interactive session and were never pinned anywhere, so the versions below are the
# latest releases on/before the mesh-generation date, resolved for this image's
# Python 3.10 (e.g. open3d 0.18.0; 0.19 dropped 3.10 wheels). `--exclude-newer`
# bounds transitive dependencies to the same point in time. aind-zarr-utils is
# pinned to its commit as of that date.
CUTOFF=2026-02-03

uv pip install --system --exclude-newer "$CUTOFF" \
    "git+https://github.com/AllenNeuralDynamics/aind-zarr-utils.git@e47cc5078aa9dbfa0499f471a817f724ea74551b"

# list of requirements
cat > /tmp/requirements.txt <<'REQ'
dask==2026.1.2
dask-image==2025.11.0
dask[distributed]==2026.1.2
h5py==3.15.1
matplotlib==3.10.8
numpy==1.26.4
nbconvert==7.17.0
oauthlib==3.3.1
opencv-python==4.11.0.86
open3d==0.18.0
pandas==2.3.3
pillow==12.1.0
plotly==6.5.2
pot==0.9.6.post1
point-cloud-utils==0.34.0
scikit-image==0.25.2
scikit-learn==1.7.2
scipy==1.15.3
seaborn==0.13.2
tifffile==2025.5.10
torch==2.10.0
tqdm==4.67.3
umap-learn==0.5.11
rtree==1.4.1
trimesh==4.11.1
zarr==2.18.3
ipykernel==7.1.0
openpyxl==3.1.5
ipympl==0.10.0
statsmodels==0.14.6
antspyx==0.6.2
REQ

uv pip install --no-cache --system --exclude-newer "$CUTOFF" -r /tmp/requirements.txt && rm /tmp/requirements.txt
